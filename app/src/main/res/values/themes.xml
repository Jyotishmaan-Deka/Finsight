<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Finsight" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Finsight.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A1040</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">#6C63FF</item>
        <item name="postSplashScreenTheme">@style/Theme.Finsight</item>
    </style>
</resources>